    {
      "parameters": {
        "jsCode": "\nconst resp = $input.first().json;\nconst newsId = $('Build 4K Ask').first().json.newsId;\nconst newsId4k = $('Build 4K Ask').first().json.newsId4k;\nconst store = $getWorkflowStaticData('global');\nif (store.pending && store.pending[newsId] && resp.result) {\n  store.pending[newsId].messageId4k = resp.result.message_id;\n}\n// Also index by newsId4k for easy lookup in the 4k branch\nif (!store.pending4k) store.pending4k = {};\nconst d = store.pending[newsId];\nstore.pending4k[newsId4k] = {\n  articleUrl4k: d.articleUrl4k, packageName: d.packageName,\n  newsId4k, messageId4k: resp.result?.message_id\n};\nreturn [{ json: { saved: true } }];\n"
      },
