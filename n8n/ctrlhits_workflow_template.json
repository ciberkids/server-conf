{
  "name": "ctrlhits Discovery + Approval",
  "nodes": [
    {
      "parameters": {
        "url": "https://ctrlhits.online/films-hd/hevc-1080p-news/rss.xml",
        "options": {}
      },
      "id": "wf2-node-0000",
      "name": "RSS 1080p",
      "type": "n8n-nodes-base.rssFeedReadTrigger",
      "typeVersion": 1,
      "position": [
        200,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst i = $input.first().json;\nconst title = i.title || '';\nconst link = i.link || i.guid || '';\nconst ym = title.match(/\\((\\d{4})\\)/);\nconst year = ym ? ym[1] : null;\nconst cleanTitle = title.replace(/\\s*\\(\\d{4}\\).*$/, '').trim();\nconst nm = link.match(/\\/(\\d+)-/);\nconst newsId = nm ? nm[1] : null;\nif (!cleanTitle || !year || !newsId) return [];\nreturn [{ json: { cleanTitle, year, newsId, articleUrl: link } }];\n"
      },
      "id": "wf2-node-0001",
      "name": "Extract 1080p Info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        120
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.themoviedb.org/3/search/movie",
        "authentication": "none",
        "sendHeaders": true,
        "options": {},
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer <TMDB_API_TOKEN>"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ $json.cleanTitle }}"
            },
            {
              "name": "year",
              "value": "={{ $json.year }}"
            },
            {
              "name": "language",
              "value": "it"
            }
          ]
        }
      },
      "id": "wf2-node-0002",
      "name": "TMDb Search 1080p",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst tmdb = $input.first().json;\nconst prev = $('Extract 1080p Info').first().json;\nconst results = tmdb.results || [];\nif (!results.length) return [];\nconst m = results[0];\nreturn [{ json: {\n  tmdbId: m.id, tmdbTitle: m.title,\n  year: prev.year, newsId: prev.newsId,\n  articleUrl: prev.articleUrl, cleanTitle: prev.cleanTitle\n}}];\n"
      },
      "id": "wf2-node-0003",
      "name": "Process TMDb 1080p",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        120
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://ctrlhits.online/films-uhd/uhd-x265-2160p-news/rss.xml",
        "authentication": "none",
        "sendHeaders": false,
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "wf2-node-0004",
      "name": "Fetch 4K RSS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1160,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst prev = $('Process TMDb 1080p').first().json;\nconst rss4kResp = $('Fetch 4K RSS').first().json;\nconst rss4kText = typeof rss4kResp === 'string' ? rss4kResp : (rss4kResp.data || rss4kResp.body || '');\n\n// Search 4K RSS for matching movie\nlet has4k = false, articleUrl4k = null, newsId4k = null;\nconst itemsRaw = rss4kText.match(/<item>[\\s\\S]*?<\\/item>/gi) || [];\nconst word0 = prev.cleanTitle.toLowerCase().split(/\\s+/)[0];\nfor (const it of itemsRaw) {\n  const tm = it.match(/<title>(.*?)<\\/title>/);\n  const lm = it.match(/<link>(.*?)<\\/link>/) || it.match(/<guid[^>]*>(.*?)<\\/guid>/);\n  if (!tm || !lm) continue;\n  const t4 = tm[1].replace(/&amp;/g,'&').replace(/&#39;/g,\"'\");\n  if (t4.includes('(' + prev.year + ')') && t4.toLowerCase().includes(word0)) {\n    has4k = true;\n    articleUrl4k = lm[1];\n    const n4m = lm[1].match(/\\/(\\d+)-/);\n    newsId4k = n4m ? n4m[1] : null;\n    break;\n  }\n}\n\n// Store in workflow static data\nconst store = $getWorkflowStaticData('global');\nif (!store.pending) store.pending = {};\nstore.pending[prev.newsId] = {\n  articleUrl: prev.articleUrl, packageName: prev.tmdbTitle + ' (' + prev.year + ')',\n  tmdbId: prev.tmdbId, cleanTitle: prev.cleanTitle, year: prev.year,\n  has4k, articleUrl4k, newsId4k, messageId: null, messageId4k: null\n};\n\n// Build Telegram message\nconst esc = s => String(s).replace(/([_*[\\]()~`>#+=|{}\\.!])/g, '\\\\$1');\nconst body = JSON.stringify({\n  chat_id: '<TELEGRAM_CHAT_ID>',\n  text: '\ud83c\udfac *' + esc(prev.tmdbTitle) + ' \\\\(' + prev.year + '\\\\)*' + (has4k ? '\\n_4K x265 also available_' : ''),\n  parse_mode: 'MarkdownV2',\n  reply_markup: {\n    inline_keyboard: [[\n      { text: '\u2b07\ufe0f Download 1080p', callback_data: 'dl:' + prev.newsId },\n      { text: '\u274c Skip', callback_data: 'skip:' + prev.newsId }\n    ]]\n  }\n});\nreturn [{ json: { newsId: prev.newsId, tgBody: body } }];\n"
      },
      "id": "wf2-node-0005",
      "name": "Prepare Pending + Notify",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/sendMessage",
        "authentication": "none",
        "options": {},
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "{{ $json.tgBody }}"
      },
      "id": "wf2-node-0006",
      "name": "Send 1080p Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst resp = $input.first().json;\nconst newsId = $('Prepare Pending + Notify').first().json.newsId;\nconst store = $getWorkflowStaticData('global');\nif (store.pending && store.pending[newsId] && resp.result) {\n  store.pending[newsId].messageId = resp.result.message_id;\n}\nreturn [{ json: { saved: true } }];\n"
      },
      "id": "wf2-node-0007",
      "name": "Save Notification Msg ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1880,
        120
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "seconds",
              "secondsInterval": 60
            }
          ]
        }
      },
      "id": "wf2-node-0008",
      "name": "Poll Telegram Every 60s",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        200,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst store = $getWorkflowStaticData('global');\nreturn [{ json: { offset: (store.last_update_id || 0) } }];\n"
      },
      "id": "wf2-node-0009",
      "name": "Get Last Update ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        500
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates",
        "authentication": "none",
        "sendHeaders": false,
        "options": {},
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "offset",
              "value": "={{ $json.offset }}"
            },
            {
              "name": "timeout",
              "value": "0"
            },
            {
              "name": "allowed_updates",
              "value": "[\"callback_query\"]"
            }
          ]
        }
      },
      "id": "wf2-node-0010",
      "name": "Telegram getUpdates",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst data = $input.first().json;\nconst updates = (data.result || []);\nconst store = $getWorkflowStaticData('global');\nlet maxId = store.last_update_id || 0;\nconst out = [];\nfor (const u of updates) {\n  if (u.update_id >= maxId) maxId = u.update_id + 1;\n  if (!u.callback_query) continue;\n  const cq = u.callback_query;\n  const [action, newsId] = cq.data.split(':');\n  out.push({ json: {\n    action, newsId,\n    callbackQueryId: cq.id,\n    messageId: cq.message?.message_id,\n    chatId: String(cq.message?.chat?.id || '<TELEGRAM_CHAT_ID>'),\n    rawData: cq.data\n  }});\n}\nstore.last_update_id = maxId;\nif (!out.length) return [];\nreturn out;\n"
      },
      "id": "wf2-node-0011",
      "name": "Parse Callback Queries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        500
      ]
    },
    {
      "parameters": {
        "method": "POST",
