      "id": "wf2-node-0004",
      "name": "Fetch 4K RSS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1168,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst prev = $('Process TMDb 1080p').first().json;\nconst rss4kResp = $('Fetch 4K RSS').first().json;\nconst rss4kText = typeof rss4kResp === 'string' ? rss4kResp : (rss4kResp.data || rss4kResp.body || '');\n\nlet has4k = false, articleUrl4k = null, newsId4k = null;\nconst itemsRaw = rss4kText.match(/<item>[\\s\\S]*?<\\/item>/gi) || [];\nconst word0 = prev.cleanTitle.toLowerCase().split(/\\s+/)[0];\nfor (const it of itemsRaw) {\n  const tm = it.match(/<title>(.*?)<\\/title>/);\n  const lm = it.match(/<link>(.*?)<\\/link>/) || it.match(/<guid[^>]*>(.*?)<\\/guid>/);\n  if (!tm || !lm) continue;\n  const t4 = tm[1].replace(/&amp;/g,'&').replace(/&#39;/g,\"'\");\n  if (t4.includes('(' + prev.year + ')') && t4.toLowerCase().includes(word0)) {\n    has4k = true;\n    articleUrl4k = lm[1];\n    const n4m = lm[1].match(/\\/(\\d+)-/);\n    newsId4k = n4m ? n4m[1] : null;\n    break;\n  }\n}\n\nconst store = $getWorkflowStaticData('global');\nif (!store.pending) store.pending = {};\nconst packageName = prev.tmdbTitle + ' (' + prev.year + ')';\nstore.pending[prev.newsId] = {\n  articleUrl: prev.articleUrl, packageName,\n  tmdbId: prev.tmdbId, cleanTitle: prev.cleanTitle, year: prev.year,\n  has4k, articleUrl4k, newsId4k, messageId: null, messageId4k: null\n};\n// Pre-populate pending4k so dlboth can find it without a second message step\nif (has4k && newsId4k) {\n  if (!store.pending4k) store.pending4k = {};\n  store.pending4k[newsId4k] = { articleUrl4k, packageName, newsId4k, messageId4k: null };\n}\n\nconst esc = s => String(s).replace(/([_*[\\]()~`>#+=|{}\\\\.!])/g, '\\\\$1');\nlet keyboard;\nif (has4k) {\n  keyboard = [\n    [\n      { text: '⬇️ 1080p',        callback_data: 'dl:'     + prev.newsId },\n      { text: '⬇️ 1080p + 4K',   callback_data: 'dlboth:' + prev.newsId }\n    ],\n    [\n      { text: '⬇️ 4K only',       callback_data: '4k:'    + newsId4k    },\n      { text: '❌ Skip',                callback_data: 'skip:'  + prev.newsId }\n    ]\n  ];\n} else {\n  keyboard = [[\n    { text: '⬇️ Download 1080p', callback_data: 'dl:'   + prev.newsId },\n    { text: '❌ Skip',                 callback_data: 'skip:' + prev.newsId }\n  ]];\n}\n\nconst body = JSON.stringify({\n  chat_id: '12373499',\n  text: '🎬 *' + esc(prev.tmdbTitle) + ' \\\\(' + prev.year + '\\\\)*' + (has4k ? '\\n_4K x265 also available_' : ''),\n  parse_mode: 'MarkdownV2',\n  reply_markup: { inline_keyboard: keyboard }\n});\nreturn [{ json: { newsId: prev.newsId, tgBody: body } }];\n"
      },
