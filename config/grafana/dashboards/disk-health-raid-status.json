    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "description": "SMART attribute 199 \u2014 counts data transfer errors between disk and SATA controller. Non-zero values strongly indicate a faulty SATA cable or connector. sdj has 228k+ errors (known bad cable).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 100
      },
      "id": 33,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "afgw1dyxyshz4b"
          },
          "expr": "smartctl_device_attribute{job=\"smartctl-optimusprime\", attribute_name=\"UDMA_CRC_Error_Count\", attribute_value_type=\"raw\"}",
          "legendFormat": "/dev/{{device}}",
          "refId": "A"
        }
      ],
      "title": "UDMA CRC Error Count (per disk)",
      "type": "timeseries"
