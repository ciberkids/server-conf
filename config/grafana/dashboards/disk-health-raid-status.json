    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
