{
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Failed Disks"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Degraded"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "node_md_disks{instance=\"optimusprime\", state=\"active\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "node_md_disks{instance=\"optimusprime\", state=\"failed\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "node_md_disks{instance=\"optimusprime\", state=\"spare\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "node_md_raid_disks{instance=\"optimusprime\"}",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "node_md_degraded{instance=\"optimusprime\"}",
          "format": "table",
          "instant": true,
          "refId": "E"
        }
      ],
      "title": "RAID Array Overview",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "state": true
            },
            "renameByName": {
              "Value #A": "Active Disks",
              "Value #B": "Failed Disks",
              "Value #C": "Spare Disks",
              "Value #D": "Required Disks",
              "Value #E": "Degraded",
              "device": "Device"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "description": "Shows current state of each md array. Active=healthy.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "Active"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "INACTIVE"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "node_md_state{instance=\"optimusprime\", state=\"active\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "MD Array State (md124, md125, md126, md127)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "description": "Ratio of synced blocks to total blocks. 1.0 = fully synced.",
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 7,
      "targets": [
        {
          "expr": "node_md_blocks_synced{instance=\"optimusprime\"} / node_md_blocks{instance=\"optimusprime\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "MD Sync Progress",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "node_md_degraded{instance=\"optimusprime\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "MD Degraded Disks",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "description": "Number of devices detected by smartctl_exporter. Note: smartctl_exporter v0.14.0 is not currently exposing per-device SMART metrics (temperature, reallocated sectors, etc). The exporter likely needs root privileges or CAP_SYS_RAWIO capability to read SMART data from disks.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 5
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "unit": "celsius"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "smartctl_device_temperature{temperature_type=\"current\"}",
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "Disk Temperature (\u00b0C)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "id": 4,
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{instance=\"optimusprime\",fstype=~\"ext4|xfs\"} / node_filesystem_size_bytes{instance=\"optimusprime\",fstype=~\"ext4|xfs\"} * 100)",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ],
      "title": "Disk Space Usage (%)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 5,
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=\"optimusprime\",device=~\"md.*\"}[5m])",
          "legendFormat": "{{device}} read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=\"optimusprime\",device=~\"md.*\"}[5m])",
          "legendFormat": "{{device}} write",
          "refId": "B"
        }
      ],
      "title": "Disk I/O (read/write bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "afgw1dyxyshz4b"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "FAILING"
                },
                "1": {
                  "color": "green",
                  "text": "HEALTHY"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 30,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "smartctl_device_smart_healthy",
          "instant": true,
          "legendFormat": "{{device}} ({{model_name}})",
          "refId": "A"
        }
      ],
      "title": "SMART Health Status",
      "type": "stat"
    },
    {
