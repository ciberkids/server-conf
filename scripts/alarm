#!/bin/bash
# alarm - manage homelab Telegram alert silences
#
# Handles two alarm channels:
#   1. Alertmanager (Prometheus/Blackbox HTTP probe failures, repeat every 4h)
#   2. systemd notify-failure@*.service (fires at container crash time)
#
# For services without a blackbox probe (URL=""), only the systemd unit is masked.
#
# Usage:
#   alarm status
#   alarm mute <service> [reason]
#   alarm unmute <service>
#   alarm list

ALERTMANAGER="http://192.168.1.10:9093"
SILENCE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/homelab-alarm-silences.json"

# service key -> Alertmanager "instance" label (exact URL in prometheus.yml blackbox targets)
# Empty string = no blackbox probe, skip Alertmanager silence
declare -A SERVICE_URL=(
  # --- Optimus Prime (192.168.1.10) ---
  [heimdall-op]="https://heimdall.optimusprime.favarohome.com"
  [grafana]="https://grafana.optimusprime.favarohome.com"
