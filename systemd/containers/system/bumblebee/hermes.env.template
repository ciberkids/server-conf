# Copy to /etc/containers/secrets/hermes.env on bumblebee and fill in values.
# This file is a template only — never commit the real .env file.
TELEGRAM_BOT_TOKEN=
# Telegram numeric user id(s) allowed to DM the bot (comma-separated)
TELEGRAM_ALLOWED_USERS=
# Default chat id for cron/proactive delivery
TELEGRAM_HOME_CHANNEL=
OPENROUTER_API_KEY=
# Local Ollama on bumblebee (reachable via host networking)
OLLAMA_BASE_URL=http://localhost:11434/v1
# Map the in-container hermes user to the host owner of /opt/data
HERMES_UID=1000
HERMES_GID=1000
