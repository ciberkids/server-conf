[Unit]
OnFailure=notify-failure@%n.service
Description=Paperless-NGX Gotenberg PDF converter
Requires=network-online.target

[Container]
ContainerName=paperless-gotenberg
Network=paperless.network
Image=docker.io/gotenberg/gotenberg:8.27
Volume=/etc/localtime:/etc/localtime:ro

Exec=gotenberg --chromium-disable-javascript=true --chromium-allow-list=file:///tmp/.*

AutoUpdate=registry

[Service]
Restart=always

[Install]
WantedBy=default.target
